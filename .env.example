# ─── LLM ───────────────────────────────────────────────────────────────────
# Clé API Mistral (obligatoire pour la config "free")
# Obtenez la vôtre gratuitement sur : https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# ─── Optionnel — autres providers ──────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# COHERE_API_KEY=...

# ─── Frontend (Docker build) ────────────────────────────────────────────────
# URL du backend telle que vue depuis le navigateur
# En local : http://localhost:8000
# En production : https://votre-domaine.com/api
VITE_API_URL=http://localhost:8000
