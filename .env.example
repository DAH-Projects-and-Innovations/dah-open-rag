# ─────────────────────────────────────────────────────────────────────────────
# Copiez ce fichier en .env et renseignez les variables selon votre mode.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Mode de configuration ────────────────────────────────────────────────────
# "free"   → Ollama local, aucune clé API
# "hybrid" → Mistral ou Gemini (clé API requise)
RAG_CONFIG=hybrid

# ── Mode HYBRID — choisissez UN provider ────────────────────────────────────

# Option A : Mistral AI (gratuit avec quota sur https://console.mistral.ai)
MISTRAL_API_KEY=your_mistral_api_key_here

# Option B : Google Gemini (gratuit avec quota sur https://aistudio.google.com/apikey)
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Mode FREE — Ollama ───────────────────────────────────────────────────────
# Ollama doit être lancé localement ou via docker-compose.free.yml
# Par défaut : http://localhost:11434 (pas besoin de changer en local)
# OLLAMA_BASE_URL=http://localhost:11434

# ── Frontend ─────────────────────────────────────────────────────────────────
# URL du backend vue depuis le navigateur (utile en production)
VITE_API_URL=http://localhost:8000
